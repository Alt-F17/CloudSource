'use client'

// Cesium widget CSS must be a static import so Next.js bundles it correctly.
// This file is always loaded via next/dynamic with { ssr: false }, so the
// import only runs in the browser.
import 'cesium/Build/Cesium/Widgets/widgets.css'

import { useEffect, useRef } from 'react'

type Destination = {
  name: string
  lat: number
  lng: number
}

interface Props {
  ionToken?: string
  destination?: Destination
  focusDestination?: boolean
}

function flyCamera(viewer: any, Cesium: any, focusDestination: boolean, destination?: Destination) {
  if (focusDestination && destination) {
    viewer.camera.flyTo({
      destination: Cesium.Cartesian3.fromDegrees(destination.lng, destination.lat, 1_650_000),
      orientation: {
        heading: 0,
        pitch: Cesium.Math.toRadians(-48),
        roll: 0,
      },
      duration: 1.2,
    })
    return
  }

  viewer.camera.flyTo({
    destination: Cesium.Cartesian3.fromDegrees(15, 20, 18_000_000),
    duration: 1.05,
  })
}

export default function CesiumViewer({
  ionToken,
  destination,
  focusDestination = false,
}: Props) {
  const containerRef = useRef<HTMLDivElement>(null)
  const viewerRef = useRef<any>(null)
  const cesiumRef = useRef<any>(null)
  const destinationEntityRef = useRef<any>(null)

  useEffect(() => {
    if (!containerRef.current || viewerRef.current) return

    const init = async () => {
      const Cesium = await import('cesium')
      cesiumRef.current = Cesium

      if (ionToken) {
        Cesium.Ion.defaultAccessToken = ionToken
      }

      const viewer = new Cesium.Viewer(containerRef.current!, {
        animation: false,
        baseLayerPicker: false,
        fullscreenButton: false,
        geocoder: false,
        homeButton: false,
        infoBox: false,
        sceneModePicker: false,
        selectionIndicator: false,
        timeline: false,
        navigationHelpButton: false,
        navigationInstructionsInitiallyVisible: false,
        msaaSamples: 2,
        // Disable Cesium's default world imagery provider.
        baseLayer: false,
      })

      let localLayer: any = null
      let switchedToFallback = false
      const switchToFallbackLayer = () => {
        if (switchedToFallback) return
        switchedToFallback = true

        if (localLayer) {
          viewer.imageryLayers.remove(localLayer, true)
          localLayer = null
        }

        viewer.imageryLayers.add(
          new Cesium.ImageryLayer(
            new Cesium.OpenStreetMapImageryProvider({
              url: 'https://tile.openstreetmap.org/',
            })
          )
        )
      }

      try {
        const localProvider = await Cesium.TileMapServiceImageryProvider.fromUrl(
          '/cesium/Assets/Textures/NaturalEarthII/'
        )
        localProvider.errorEvent.addEventListener(() => {
          switchToFallbackLayer()
        })

        localLayer = new Cesium.ImageryLayer(localProvider)
        viewer.imageryLayers.add(localLayer)
      } catch {
        switchToFallbackLayer()
      }

      viewer.terrainProvider = new Cesium.EllipsoidTerrainProvider()
      viewer.scene.globe.baseColor = new Cesium.Color(0.07, 0.09, 0.15, 1)
      viewer.scene.globe.enableLighting = false
      viewer.scene.backgroundColor = new Cesium.Color(0.02, 0.03, 0.08, 1)

      viewerRef.current = viewer
      flyCamera(viewer, Cesium, focusDestination, destination)
    }

    init().catch(console.error)

    return () => {
      if (viewerRef.current && !viewerRef.current.isDestroyed()) {
        viewerRef.current.destroy()
        viewerRef.current = null
      }
      destinationEntityRef.current = null
      cesiumRef.current = null
    }
  }, [ionToken])

  useEffect(() => {
    const viewer = viewerRef.current
    const Cesium = cesiumRef.current
    if (!viewer || !Cesium) return

    if (destination) {
      if (!destinationEntityRef.current) {
        destinationEntityRef.current = viewer.entities.add({
          name: `${destination.name} destination`,
          position: Cesium.Cartesian3.fromDegrees(destination.lng, destination.lat),
          point: {
            pixelSize: 12,
            color: Cesium.Color.fromCssColorString('#F472B6'),
            outlineColor: Cesium.Color.WHITE,
            outlineWidth: 2,
          },
          label: {
            text: destination.name,
            font: '600 14px DM Sans, sans-serif',
            style: Cesium.LabelStyle.FILL_AND_OUTLINE,
            fillColor: Cesium.Color.WHITE,
            outlineColor: Cesium.Color.BLACK,
            outlineWidth: 3,
            showBackground: true,
            backgroundColor: Cesium.Color.fromCssColorString('rgba(10,15,30,0.65)'),
            pixelOffset: new Cesium.Cartesian2(0, -24),
          },
        })
      } else {
        destinationEntityRef.current.position = Cesium.Cartesian3.fromDegrees(
          destination.lng,
          destination.lat
        )
        if (destinationEntityRef.current.label) {
          destinationEntityRef.current.label.text = destination.name
        }
      }
    }

    flyCamera(viewer, Cesium, focusDestination, destination)
  }, [destination, focusDestination])

  return <div ref={containerRef} className="h-full w-full" />
}
